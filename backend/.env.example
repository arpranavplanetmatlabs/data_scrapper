# Search provider: "google" | "serpapi"
SEARCH_PROVIDER=google

# Required only if SEARCH_PROVIDER=serpapi
SERPAPI_KEY=your_serpapi_key_here

# Number of search results to fetch per query
SEARCH_RESULTS_LIMIT=10

# Max pages to visit per job
MAX_PAGES_PER_JOB=30

# Storage root for downloaded PDFs
DATA_DIR=./data

# SQLite database path
DATABASE_URL=sqlite+aiosqlite:///./tds.db

# Playwright fallback: enable/disable (true/false)
PLAYWRIGHT_ENABLED=true
